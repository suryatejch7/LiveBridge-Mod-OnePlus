{
  "smart_rules": [
    {
      "id": "food",
      "max_stage": 4,
      "package_hints": [
        "kfc",
        "ubereats",
        "doordash",
        "grubhub",
        "delivery",
        "еда",
        "food"
      ],
      "text_triggers": [
        "заказ",
        "order",
        "курьер",
        "courier",
        "еда",
        "food",
        "ресторан",
        "restaurant"
      ],
      "exclude_patterns": [
        "(с дн[её]м рождения|happy birthday|birthday)",
        "(дарим\\s+скидк|скидк[\\p{L}]*\\s*\\d+%|\\d+%\\s*(скидк|off)|акци[яи]|промокод|promo\\s*code|coupon|cash\\s*back|кэшб[еэ]к)",
        "(payment\\s*(?:failure|failed|declined|unsuccessful)|оплат[аы][^\\n]*(?:не\\s*прошл|ошибк|отклон|не\\s*успеш)|неудачн[а-я\\s]*оплат)",
        "(при\\s+заказе\\s+от\\s*\\d|order\\s+from\\s*\\d)",
        "(почт[аы]\\s+росси|посыл(?:к|ок)|маркетплейс|отделени[ея]|трек-?номер|tracking|shipment|parcel|пункт\\s*выдачи)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(доставлен(?:а|о|ы)?|получен(?:а|о|ы)?|вручен(?:а|о|ы)?|delivery completed|order delivered|delivered|completed|приятного аппетита|enjoy(?: your meal)?)"
        },
        {
          "stage": 3,
          "pattern": "(курьер[^\\n]*(в пути|едет|уже рядом|подъезжа(?:ет|л)|забрал(?: заказ)?)|out for delivery|on the way|heading to you|едет к вам|доставля(?:ется|ем|ют)|передан[^\\n]*курьеру|courier[^\\n]*(picked up|heading|on the way|nearby))"
        },
        {
          "stage": 2,
          "pattern": "((?:заказ|order)[^\\n]{0,40}(готов(?:\\b|\\s)|собран|упакован|готов к выдаче|готов для выдачи|готов к самовывозу|ready(?:\\s+for\\s+(?:pickup|delivery))?)|собран(?:о|ы)?\\b|упакован(?:о|ы)?\\b|готов к выдаче|готов для выдачи|готов к самовывозу|ready for pickup|ready for delivery|packed|almost ready)"
        },
        {
          "stage": 1,
          "pattern": "((?:заказ|order)[^\\n]{0,40}(собира(?:ем|ют|ется)|готов(?:ится|им|ят)|начали готовить|в работе|в процессе)|собира(?:ем|ют|ется)[^\\n]{0,30}(?:заказ|order)|preparing|in kitchen|is being prepared|is being cooked|being cooked|cooking|assembling)"
        },
        {
          "stage": 0,
          "pattern": "(заказ[^\\n]*(принят|создан|оформлен|подтвержд[её]н|оплачен)|order[^\\n]*(received|accepted|confirmed|created|placed|paid)|оплат[аы][^\\n]*(прошла|подтверждена|успешна|принята)|payment[^\\n]*(successful|confirmed|received|accepted))"
        }
      ]
    },
    {
      "id": "taxi",
      "max_stage": 4,
      "package_hints": ["taxi", "uber", "lyft", "bolt", "yango", "yandex"],
      "text_triggers": [
        "такси",
        "taxi",
        "ride",
        "поездка",
        "водитель",
        "driver"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(поездка завершена|trip completed|arrived at destination|you'?ve arrived)"
        },
        {
          "stage": 3,
          "pattern": "(поездка началась|trip started|ride started|enjoy your ride)"
        },
        {
          "stage": 2,
          "pattern": "(едет к вам|подъезжает|driver[^\\n]*arriving|arriving in|on the way)"
        },
        {
          "stage": 1,
          "pattern": "(водитель найден|driver found|driver assigned|matched with driver)"
        },
        {
          "stage": 0,
          "pattern": "(поиск[^\\n]*водител|ищем[^\\n]*водител|searching for (a )?driver|finding driver)"
        }
      ]
    },
    {
