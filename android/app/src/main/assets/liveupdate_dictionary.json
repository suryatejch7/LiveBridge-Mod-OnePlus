{
  "smart_rules": [
    {
      "id": "food",
      "max_stage": 4,
      "package_hints": [
        "kfc",
        "ubereats",
        "doordash",
        "grubhub",
        "delivery",
        "еда",
        "food"
      ],
      "text_triggers": [
        "заказ",
        "order",
        "доставка",
        "delivery",
        "курьер",
        "courier",
        "еда",
        "food"
      ],
      "exclude_patterns": [
        "(с дн[её]м рождения|happy birthday|birthday)",
        "(дарим\\s+скидк|скидк[\\p{L}]*\\s*\\d+%|\\d+%\\s*(скидк|off)|акци[яи]|промокод|promo\\s*code|coupon|cash\\s*back|кэшб[еэ]к)",
        "(при\\s+заказе\\s+от\\s*\\d|order\\s+from\\s*\\d)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(доставлен|доставлено|получен|получено|delivered|delivery completed|completed|приятного аппетита|enjoy)"
        },
        {
          "stage": 3,
          "pattern": "(курьер[^\\n]*в пути|out for delivery|on the way|едет к вам|доставля(?:ется|ем)|передан[^\\n]*курьеру|courier[^\\n]*(picked up|heading|on the way))"
        },
        {
          "stage": 2,
          "pattern": "(собираем|собран|упаковываем|упакован|почти готов|готов к выдаче|готов для выдачи|packed|almost ready|ready for pickup|ready)"
        },
        {
          "stage": 1,
          "pattern": "(готовится|готовим|начали готовить|preparing|in kitchen|is being prepared|is being cooked|being cooked|cooking|cooked for you)"
        },
        {
          "stage": 0,
          "pattern": "(заказ[^\\n]*(принят|создан|оформлен|подтвержд[её]н|оплачен)|order[^\\n]*(received|accepted|confirmed|created|placed|paid)|оплат[аы][^\\n]*(прошла|подтверждена|успешна)|payment[^\\n]*(successful|confirmed|received))"
        }
      ]
    },
    {
      "id": "taxi",
      "max_stage": 4,
      "package_hints": ["taxi", "uber", "lyft", "bolt", "yango", "yandex"],
      "text_triggers": [
        "такси",
        "taxi",
        "ride",
        "поездка",
        "водитель",
        "driver"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(поездка завершена|trip completed|arrived at destination|you'?ve arrived)"
        },
        {
          "stage": 3,
          "pattern": "(поездка началась|trip started|ride started|enjoy your ride)"
        },
        {
          "stage": 2,
          "pattern": "(едет к вам|подъезжает|driver[^\\n]*arriving|arriving in|on the way)"
        },
        {
          "stage": 1,
          "pattern": "(водитель найден|driver found|driver assigned|matched with driver)"
        },
        {
          "stage": 0,
          "pattern": "(поиск[^\\n]*водител|ищем[^\\n]*водител|searching for (a )?driver|finding driver)"
        }
      ]
    },
    {
      "id": "navigation",
      "max_stage": 4,
      "package_hints": [
        "ru.yandex.yandexmaps",
        "google.android.apps.maps",
        "waze",
        "here",
        "tomtom",
        "maps",
        "map",
        "navigator",
        "navigation",
        "navi"
      ],
      "text_triggers": [
        "маршрут",
        "навигац",
        "поверните",
        "сверните",
        "развернитесь",
        "пункт назначения",
        "съезд",
        "кругов",
        "route",
        "turn left",
        "turn right",
        "keep left",
        "keep right",
        "take exit",
        "u-turn",
        "roundabout",
        "destination"
      ],
      "exclude_patterns": [
        "(с дн[её]м рождения|happy birthday|birthday)",
        "(дарим\\s+скидк|скидк[\\p{L}]*\\s*\\d+%|\\d+%\\s*(скидк|off)|акци[яи]|промокод|promo\\s*code|coupon|cash\\s*back|кэшб[еэ]к)",
        "(вы получили это письмо|отписаться от рассыл|unsubscribe|newsletter|follow us|скачать приложение|download app)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(вы прибыли|пункт назначения достигнут|маршрут заверш[её]н|завершить маршрут|finish the route|arrived|destination reached|you'?ve arrived)"
        },
        {
          "stage": 3,
          "pattern": "(пункт назначения[^\\n]*(справа|слева)|destination (is )?on (your )?(right|left)|almost there|почти на месте|до пункта назначения)"
        },
        {
          "stage": 2,
          "pattern": "(через\\s*\\d+[\\d\\s.,]*(м|км|m|km|ft|mi)|\\b\\d+\\s*(m|km|ft|mi)\\b|поверните|сверните|держитесь|развернитесь|пройдите|двигайтесь|продолжайте движение|возьмите съезд|выйдите|turn (left|right)|keep (left|right)|continue|head\\s|take\\s+the|exit|merge|roundabout|u-?turn)"
        },
        {
          "stage": 1,
          "pattern": "(маршрут построен|маршрут начат|navigation started|starting route|follow the route|route started)"
        }
      ]
    }
  ],
  "blocked_source_packages": ["ru.dublgis.dgismobile"],
  "known_navigation_packages": [
    "ru.yandex.yandexmaps",
    "com.google.android.apps.maps",
    "com.waze"
  ],
  "navigation_package_markers": ["navigation", "navigator", ".maps"],
  "navigation_distance_pattern": "(?<!\\d)\\d{1,4}(?:[\\s.,]\\d{1,2})?\\s*(?:км|km|м|m|mi|ft|миль|фут)\\b",
  "otp_strong_triggers": [
    "otp",
    "one-time password",
    "one time password",
    "verification code",
    "confirmation code",
    "confirm code",
    "security code",
    "login code",
    "account code",
    "payment code",
    "passcode",
    "2fa",
    "auth code",
    "sms code",
    "код подтверждения",
    "код для подтверждения",
    "код входа",
    "код для входа",
    "код для добавления",
    "код для добавления устройства",
    "код оплаты",
    "код аккаунта",
    "одноразовый",
    "код из смс"
  ],
  "otp_loose_trigger_pattern": "(?:(?:\\bcode\\b|\\bкод\\b)\\s*[:#-]?\\s*\\d{4,8})",
  "money_context_pattern": "(₽|руб\\.?|rub|usd|eur|kzt|тенге|р\\.|\\$|€|price|total|amount|sum|сумм|цена|стоимост|итого)",
  "text_progress_percent_pattern": "(?<!\\d)(\\d{1,3})\\s*%",
  "text_progress_context_window": 80,
  "text_progress_include_context_pattern": "(прогресс|выполн(?:ен|ено|яется|ение)|загруз(?:к|жается|жено)|скач(?:ив|ивает|ивание)|обновл(?:ен|ение|яется)|синхрон(?:изац|изируется)|обработ(?:к|ан|ает)|установ(?:к|лен)|готов(?:о|ится)?|остал(?:ось|ось)|remaining|progress|completed|completing|downloading|uploading|updating|installing|sync(?:ing)?|processing|processed|ready|done)",
  "text_progress_exclude_context_pattern": "(скид|акци|промокод|промо|купон|распрод|кэшб[еэ]к|кешб[еэ]к|discount|promo|coupon|sale|cashback|off\\b|выгод|bonus|бонус|save|deal|special\\s+offer|limited\\s+time|дарим|подар|при\\s+заказ|при\\s+покуп|minimum\\s+order|order\\s+from|в\\s+приложени\\S*\\s+акци|\\d{2,7}\\s*(?:₽|руб\\.?|рубл(?:ей|я|ь)?|rur|usd|eur|\\$|€|kzt|тенге)|влажност|humidity|погод|weather|температур|temperature|давлен|pressure|осадк|precip|комисси|commission|fee\\b|налог|tax\\b|apr\\b|ставк|годов(?:ых|ая)?\\s*процент|процентн(?:ая|ые|ых)\\s+ставк|ипотек|кредит|депозит|вклад)",
  "weather_package_hints": [
    "weather",
    "meteo",
    "accuweather",
    "weatherchannel",
    "gismeteo",
    "yandex.weather",
    "pogoda",
    "clime",
    "1weather",
    "todayweather"
  ],
  "weather_context_pattern": "(погод|weather|температур|temperature|ощущаетс|feels like|влажност|humidity|ветер|wind|осадк|precip|давлен|pressure|прогноз|forecast|uv|aqi)",
  "weather_temperature_pattern": "(?<!\\d)([+\\-−]?\\d{1,3})\\s*(?:°\\s*(?:c|f|с|ф)?|℃|℉)",
  "otp_code_patterns": [
    "(?<!\\d)(\\d{4,8})(?!\\d)",
    "(?<!\\d)(\\d(?:[\\s-]?\\d){3,7})(?!\\d)"
  ],
  "order_context_hints": ["заказ", "order", "delivery", "достав"],
  "entity_token_patterns": [
    "(?:заказ|order|trip|ride|поездк[аы])\\s*(?:#|№)?\\s*([a-z0-9-]{2,16})",
    "(?:#|№)\\s*([a-z0-9-]{2,16})",
    "\\b(\\d{4,10})\\b"
  ],
