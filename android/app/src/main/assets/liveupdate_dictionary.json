      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(вы прибыли|пункт назначения достигнут|маршрут заверш[её]н|завершить маршрут|finish the route|arrived|destination reached|you'?ve arrived)"
        },
        {
          "stage": 3,
          "pattern": "(пункт назначения[^\\n]*(справа|слева)|destination (is )?on (your )?(right|left)|almost there|почти на месте|до пункта назначения)"
        },
        {
          "stage": 2,
          "pattern": "(через\\s*\\d+[\\d\\s.,]*(м|км|m|km|ft|mi)|\\b\\d+\\s*(m|km|ft|mi)\\b|поверните|сверните|держитесь|развернитесь|пройдите|двигайтесь|продолжайте движение|возьмите съезд|выйдите|turn (left|right)|keep (left|right)|continue|head\\s|take\\s+the|exit|merge|roundabout|u-?turn)"
        },
        {
          "stage": 1,
          "pattern": "(маршрут построен|маршрут начат|navigation started|starting route|follow the route|route started)"
        }
      ]
    },
    {
      "id": "external_device",
